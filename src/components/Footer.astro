---
import { categories } from "../data/categories";
---

<footer class="mt-24 border-t border-ink-100 bg-ink-50/60">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="flex items-center gap-2 font-bold text-ink-900">
          <span
            class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 text-white"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M4 7h16M4 12h10M4 17h7"></path>
            </svg>
          </span>
          TheMarketStack
        </div>
        <p class="mt-3 max-w-xs text-sm text-ink-500">
          Side-by-side comparisons of the best marketing SaaS, so you can pick
          the right stack with confidence.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-ink-900">Categories</h4>
        <ul class="mt-3 space-y-2 text-sm">
          {
            categories.slice(0, 5).map((c) => (
              <li>
                <a
                  href={`/categories/${c.slug}`}
                  class="text-ink-500 hover:text-brand-700"
                >
                  {c.shortName}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-ink-900">Explore</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href="/tools" class="text-ink-500 hover:text-brand-700"
              >All tools</a
            >
          </li>
          <li>
            <a href="/categories" class="text-ink-500 hover:text-brand-700"
              >Categories</a
            >
          </li>
          <li>
            <a href="/compare" class="text-ink-500 hover:text-brand-700"
              >Comparison</a
            >
          </li>
          <li>
            <a href="/alternatives" class="text-ink-500 hover:text-brand-700"
              >Alternatives</a
            >
          </li>
          <li>
            <a href="/resources" class="text-ink-500 hover:text-brand-700"
              >Resources</a
            >
          </li>
          <li>
            <a href="/submit" class="text-ink-500 hover:text-brand-700"
              >Add your tool</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-ink-900">About</h4>
        <p class="mt-3 text-sm text-ink-500">
          TheMarketStack is a demo comparison site. Ratings and data shown are
          illustrative sample data.
        </p>
      </div>
    </div>

    <div class="mt-10 border-t border-ink-100 pt-6 text-xs text-ink-400">
      &copy; {new Date().getFullYear()} TheMarketStack. Sample data for demonstration
      purposes.
    </div>
  </div>
</footer>
